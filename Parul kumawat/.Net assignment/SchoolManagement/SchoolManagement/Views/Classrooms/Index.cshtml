@model IEnumerable<SchoolManagement.Models.Classroom>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New Classroom</a>
</p>

<div>
    <a asp-controller="Home" asp-action="DisplayStudents">Back to Students List</a>
</div>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ClassroomYear)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Section)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Remarks)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.GradeId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TeacherId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Grade)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Teacher)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.ClassroomYear)
            </td>
            <td>
                @Html.DisplayFor(model => item.Section)
            </td>
            <td>
                @Html.DisplayFor(model => item.Status)
            </td>
            <td>
                @Html.DisplayFor(model => item.Remarks)
            </td>
            <td>
                @Html.DisplayFor(model => item.GradeId)
            </td>
            <td>
                @Html.DisplayFor(model => item.TeacherId)
            </td>
            <td>
                @Html.DisplayFor(model => item.Grade)
            </td>
            <td>
                @Html.DisplayFor(model => item.Teacher)
            </td>
            <td>
                    <a asp-controller="Classrooms" asp-action="Create" asp-route-id="@item.ClassroomId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ClassroomId">Details</a> |
                    <a asp-controller="Classrooms" asp-action="Delete" asp-route-id="@item.ClassroomId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
