@model RoleBasedAuth.Models.ViewModel.EditUserProfileViewModel

@{
    ViewData["Title"] = "Edit Profile";
}

<div class="container mt-4">
    <div class="card shadow p-4">
        <h2 class="text-center mb-4">Edit Profile</h2>

        
        <form asp-action="EditUserProfile" method="post" enctype="multipart/form-data">

            
            <div class="text-center mb-3">
                @if (!string.IsNullOrEmpty(Model.ExistingImage))
                {
                    <img src="~/images/@Model.ExistingImage"width="150"height="150" style="border-radius:50%; object-fit:cover;" />
                }
            </div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" readonly />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Age" class="form-label"></label>
                <input asp-for="Age" class="form-control" />
                <span asp-validation-for="Age" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ImageFile" class="form-label"> Change Profile Picture</label>
                <input asp-for="ImageFile" type="file" class="form-control" />
                @* <span asp-validation-for="ImageFile" class="text-danger"></span> *@
            </div>

          
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"> Update Profile</button>
                <a asp-controller="Home" asp-action="ChangePassword" class="btn btn-secondary"> Change Password</a>

                <a asp-controller="Home" asp-action="ManageProfile" class="btn btn-secondary">Cancel</a>
            </div>

        </form>
    </div>
    

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
