@model RoleBasedAuth.Models.Registration

@{
    ViewData["Title"] = "Register";
}

<h2 style="text-align:center; margin-top:40px;">Register</h2>

<div style="width:300px; margin:auto; margin-top:30px;">

    <form asp-controller="Home" asp-action="Register" method="post">

        <div asp-validation-summary="ModelOnly" style="color:red;"></div>

        <div style="margin-bottom:15px;">
            <input asp-for="Name" placeholder="Name" style="width:100%; padding:10px;" />
            <span asp-validation-for="Name" style="color:red;"></span>
        </div>

        <div style="margin-bottom:15px;">
            <input asp-for="Age" placeholder="Age"  style="width:100%; padding:10px;" />
            <span asp-validation-for="Age" style="color:red;"></span>
        </div>

        <div style="margin-bottom:15px;">
            <input asp-for="Email" placeholder="Email" style="width:100%; padding:10px;" />
            <span asp-validation-for="Email" style="color:red;"></span>
        </div>

        <div style="margin-bottom:15px;">
            <input type="password" asp-for="Password" placeholder="Password" style="width:100%; padding:10px;" />
            <span asp-validation-for="Password" style="color:red;"></span>
        </div>

        <div style="margin-bottom:20px;">
            <input type="password" asp-for="ConfirmPassword" placeholder="Confirm Password" style="width:100%; padding:10px;" />
            <span asp-validation-for="ConfirmPassword" style="color:red;"></span>
        </div>

        <button type="submit" style="width:100%; padding:10px;"> Register</button>

    </form>

 <p style="text-align:center; margin-top:15px;"> <a asp-controller="Home" asp-action="Login"> Already have an account?</a> </p>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}