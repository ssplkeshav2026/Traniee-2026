@model List<EmpTaskManagementMVC.ViewModel.Tasks.TaskViewModel>

<h2>My Tasks</h2>


<table border="1" cellpadding="8">

    <tr>
        <th>Title</th>
        <th>Description</th>
        <th>Due Date</th>
        <th>Status</th>
       <th>Actions</th> 
    </tr>

    @if (Model != null && Model.Count > 0)
    {
        foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Description</td>
                <td>@item.DueDate.ToString("yyyy-MM-dd")</td>
                <td>@item.Status</td>
                <td>
                    <a asp-controller="Emp" asp-action="UpdateTaskStatus" asp-route-id="@item.Id">UpdateStatus</a>
                </td>
            </tr>
        }
    }
    

</table>

