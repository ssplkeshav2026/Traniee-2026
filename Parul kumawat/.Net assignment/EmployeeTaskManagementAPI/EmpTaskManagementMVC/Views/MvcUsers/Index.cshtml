@model IEnumerable<EmpTaskManagementMVC.ViewModel.Users.UsersViewModel>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-controller="MvcAuth" asp-action="Register">Create New User</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.UserName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.UserName)
            </td>
            <td>
                @Html.DisplayFor(model => item.Email)
            </td>
            <td>
                <a asp-controller="MvcUsers" asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-controller="MvcUsers" asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-controller="MvcUsers" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
