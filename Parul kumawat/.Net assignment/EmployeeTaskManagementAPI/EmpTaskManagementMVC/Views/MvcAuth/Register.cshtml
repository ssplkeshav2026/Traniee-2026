@model EmpTaskManagementMVC.ViewModel.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<h2 style="text-align:center; margin-top:40px;">Register</h2>

<div style="width:300px; margin:auto; margin-top:30px;">

    <form asp-controller="MvcAuth" asp-action="Register" method="post">

        <div asp-validation-summary="All" style="color:red;"></div>

        <div style="margin-bottom:15px;">
            <input asp-for="FirstName" placeholder=" First Name" style="width:100%; padding:10px;" />
            <span asp-validation-for="FirstName" style="color:red;"></span>
        </div>
        <div style="margin-bottom:15px;">
            <input asp-for="LastName" placeholder=" Last Name" style="width:100%; padding:10px;" />
            <span asp-validation-for="LastName" style="color:red;"></span>
        </div>
        

        <div style="margin-bottom:15px;">
            <input asp-for="Email" placeholder="Email" style="width:100%; padding:10px;" />
            <span asp-validation-for="Email" style="color:red;"></span>
        </div>

        <div style="margin-bottom:15px;">
            <input type="password" asp-for="Password" placeholder="Password" style="width:100%; padding:10px;" />
            <span asp-validation-for="Password" style="color:red;"></span>
        </div>

        

        <button type="submit" style="width:100%; padding:10px;"> Register</button>

    </form>

    <p style="text-align:center; margin-top:15px;"> <a asp-controller="MvcAuth" asp-action="Login"> Already have an account?</a> </p>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}