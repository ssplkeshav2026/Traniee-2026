@model dynamic

<h2>User Management</h2>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>User Name</th>
            <th>Email</th>
            <th>Roles</th>
            <th>Status</th> 
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var user in Model)
        {
              if (user.Email == "admin@gmail.com")
        {
            continue;
        }

            <tr>

                <td>@user.UserName</td>

                <td>@user.Email</td>

                <td>

                    <form asp-action="UpdateRole" method="post">

                        <input type="hidden"
                               name="userId"
                               value="@user.Id" />

                        <div class="form-check">

                            <input class="form-check-input"
                                   type="checkbox"
                                   name="roles"
                                   value="Admin"
                            @(user.Roles.Contains("Admin") ? "checked" : "") />

                            <label class="form-check-label">
                                Admin
                            </label>

                        </div>

                        <div class="form-check">

                            <input class="form-check-input"
                                   type="checkbox"
                                   name="roles"
                                   value="Manager"
                            @(user.Roles.Contains("Manager") ? "checked" : "") />

                            <label class="form-check-label">
                                Manager
                            </label>

                        </div>

            
                        <div class="form-check">

                            <input class="form-check-input"
                                   type="checkbox"
                                   name="roles"
                                   value="Member"
                            @(user.Roles.Contains("Member") ? "checked" : "") />

                            <label class="form-check-label">
                                Member
                            </label>

                        </div>

                        <button type="submit"
                                class="btn btn-primary btn-sm mt-2">
                            Save
                        </button>

                    </form>

                </td>

                <td>

                    @if (user.IsActive)
                    {
                        <span class="badge bg-success">
                            Active
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            Inactive
                        </span>
                    }

                </td>

                <td>

                    <form asp-action="ToggleStatus" method="post">

                        <input type="hidden"
                               name="userId"
                               value="@user.Id" />

                        @if (user.IsActive)
                        {
                            <button type="submit"
                                    class="btn btn-danger btn-sm">
                                Inactive
                            </button>
                        }
                        else
                        {
                            <button type="submit"
                                    class="btn btn-success btn-sm">
                                Active
                            </button>
                        }

                    </form>

                </td>

            </tr>
        }

    </tbody>

</table>