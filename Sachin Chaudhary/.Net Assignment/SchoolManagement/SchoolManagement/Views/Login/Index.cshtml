@{
    ViewData["Title"] = "Login";
   
}

<style>

    body {
        background: linear-gradient(to right, #f8f9fa, #e9ecef);
        font-family: 'Segoe UI', sans-serif;
    }

    .login-section {
        min-height: 100vh;
        display: flex;
        align-items: center;
    }

    .login-card {
        border: none;
        overflow: hidden;
        border-radius: 20px;
        box-shadow: 0 10px 35px rgba(0,0,0,0.15);
    }

    .left-side {
        padding: 50px;
        background-color: white;
    }

    .right-side {
        background: linear-gradient(to right, #ee7724, #d8363a, #dd3675, #b44593);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px;
    }

    .right-side-content {
        max-width: 400px;
    }

    .logo-img {
        width: 120px;
        margin-bottom: 20px;
    }

    .form-control {
        height: 50px;
        border-radius: 10px;
    }

    .btn-login {
        background: linear-gradient(to right, #ee7724, #d8363a, #dd3675, #b44593);
        border: none;
        color: white;
        border-radius: 10px;
        height: 50px;
        font-size: 18px;
        transition: 0.3s;
    }

        .btn-login:hover {
            transform: translateY(-2px);
            opacity: 0.9;
        }

    .create-btn {
        border-radius: 10px;
    }

    @@media(max-width: 991px) {

        .right-side {
            display: none;
        }

        .left-side {
            padding: 30px;
        }
    }

</style>

<section class="login-section">

    <div class="container">

        <div class="row justify-content-center">

            <div class="col-lg-10">

                <div class="card login-card">

                    <div class="row g-0">

                        <!-- LEFT SIDE -->
                        <div class="col-lg-6">

                            <div class="left-side">

                                <div class="text-center">

                                    <img src="https://mdbcdn.b-cdn.net/img/Photos/new-templates/bootstrap-login-form/lotus.webp"
                                         class="logo-img"
                                         alt="logo">

                                    <h3 class="fw-bold mb-4">
                                        Welcome Back
                                    </h3>

                                </div>

                                <form asp-controller="Account"
                                      asp-action="Login"
                                      method="post">

                                    <p class="text-muted mb-4">
                                        Please login to your account
                                    </p>

                                    <div class="mb-4">

                                        <label class="form-label">
                                            Username
                                        </label>

                                        <input type="text"
                                               name="Username"
                                               class="form-control"
                                               placeholder="Enter email or phone"
                                               required />

                                    </div>

                                    <div class="mb-4">

                                        <label class="form-label">
                                            Password
                                        </label>

                                        <input type="password"
                                               name="Password"
                                               class="form-control"
                                               placeholder="Enter password"
                                               required />

                                    </div>

                                    <div class="d-grid mb-3">

                                        <button type="submit"
                                                class="btn btn-login">
                                            Login
                                        </button>

                                    </div>

                                    <div class="text-center mb-4">

                                        <a asp-controller="Account"
                                               asp-action="ForgotPassword"
                                               class="text-decoration-none">
                                            Forgot password?
                                        </a>

                                    </div>

                                    <div class="d-flex justify-content-center align-items-center">

                                        <p class="mb-0 me-2">
                                            Don't have an account?
                                        </p>

                                        <a asp-controller="Account"
                                               asp-action="Register"
                                               class="btn btn-outline-danger create-btn">
                                            Create New
                                        </a>

                                    </div>

                                </form>

                            </div>

                        </div>

                        <!-- RIGHT SIDE -->
                        <div class="col-lg-6 right-side">

                            <div class="right-side-content">

                                <h2 class="fw-bold mb-4">
                                    School Management System
                                </h2>

                                <p class="lead">
                                    Manage students, classrooms, exams,
                                    courses, and results efficiently with
                                    a modern and secure management system.
                                </p>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>