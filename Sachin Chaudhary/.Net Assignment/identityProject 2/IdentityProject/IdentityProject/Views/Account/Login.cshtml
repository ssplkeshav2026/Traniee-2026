@model IdentityProject.Models.LoginViewModel

<div class="container d-flex justify-content-center align-items-center vh-100">

    <div class="card shadow p-4 rounded-4" style="width: 400px;">

        <h2 class="text-center mb-4 text-primary">
            Login
        </h2>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

       
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }

        <form asp-action="Login" method="post" autocomplete="off">

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

          
            <div class="mb-3">

                <label asp-for="Email" class="form-label fw-bold">
                    Email
                </label>

                <input asp-for="Email"
                       class="form-control"
                       placeholder="Enter your email"
                       autocomplete="off" />

                <span asp-validation-for="Email"
                      class="text-danger">
                </span>

            </div>

            <!-- Password -->
            <div class="mb-3">

                <label asp-for="Password" class="form-label fw-bold">
                    Password
                </label>

                <input asp-for="Password"
                       type="password"
                       class="form-control"
                       placeholder="Enter your password"
                       autocomplete="new-password" />

                <span asp-validation-for="Password"
                      class="text-danger">
                </span>

            </div>

            <!-- Remember Me -->
            <div class="form-check mb-3">

                <input asp-for="RememberMe"
                       class="form-check-input" />

                <label asp-for="RememberMe"
                       class="form-check-label">
                    Remember Me
                </label>

            </div>

            <!-- Login Button -->
            <button type="submit"
                    class="btn btn-primary w-100 rounded-3">
                Login
            </button>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}