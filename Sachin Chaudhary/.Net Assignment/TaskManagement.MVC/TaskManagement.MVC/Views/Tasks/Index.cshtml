@model IEnumerable<TaskManagement.MVC.ViewModels.TaskViewModel>

@{
    ViewData["Title"] = "Task List";
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 10px;">
        <div class="d-flex align-items-center">
            <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
            <div>
                <strong>System Error:</strong> @TempData["ErrorMessage"]
            </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-list-task"></i> Task List</h2>
    <a asp-controller="Tasks" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Create New Task
    </a>
</div>

<div class="card-box">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Due Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                            No tasks found in system database.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var task in Model)
                    {
                        <tr id="task-row-@task.Id">
                            <td><strong>#@task.Id</strong></td>
                            <td><span class="fw-bold text-dark">@task.Title</span></td>
                            <td>
                                <span class="text-muted text-wrap d-inline-block" style="max-width: 250px;">
                                    @task.Description
                                </span>
                            </td>
                            <td>
                                @if (task.Status == "Completed")
                                {
                                    <span class="badge bg-success px-3 py-2">Completed</span>
                                }
                                else if (task.Status == "In Progress")
                                {
                                    <span class="badge bg-info text-dark px-3 py-2">In Progress</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark px-3 py-2">Pending</span>
                                }
                            </td>
                            <td>@task.DueDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-controller="Tasks" asp-action="Details" asp-route-id="@task.Id" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                    <a asp-controller="Tasks" asp-action="Edit" asp-route-id="@task.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteTask(@task.Id)">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        function deleteTask(id) {
        if (confirm("Are you sure you want to permanently delete Task #" + id + "?")) {
        $.ajax({
        url: '/Tasks/DeleteAjax/' + id,
        type: 'POST',
        success: function (response) {
        alert(response.message || "Task deleted successfully.");
                        
    
        $("#task-row-" + id).fadeOut(400, function() {
        $(this).remove();
        });
        },
        error: function (xhr) {
        var errorMsg = "Failed to complete background removal sync.";
        if (xhr.responseJSON && xhr.responseJSON.message) {
        errorMsg = xhr.responseJSON.message;
        }
        alert("Error: " + errorMsg);
        }
        });
        }
        }
    </script>
}