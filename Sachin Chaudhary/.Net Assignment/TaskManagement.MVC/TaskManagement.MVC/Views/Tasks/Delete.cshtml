@model TaskManagement.MVC.ViewModels.TaskViewModel


@{
    ViewData["Title"]="Delete Task";
}



<div class="card-box">


<h2 class="text-danger">

<i class="bi bi-trash"></i>

Delete Task

</h2>



<hr/>


<h4>
Are you sure you want to delete this task?
</h4>



<div class="mt-4">


<h5>
@Model.Title
</h5>


<p>
@Model.Description
</p>


</div>




<form asp-action="DeleteConfirmed"
method="post">


<input type="hidden"
name="id"
value="@Model.Id"/>



<button type="submit"
class="btn btn-danger">


<i class="bi bi-trash"></i>

Yes Delete


</button>



<a asp-action="Index"
class="btn btn-secondary">

Cancel

</a>



</form>


</div>