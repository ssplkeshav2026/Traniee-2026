@model TaskManagement.MVC.ViewModels.EditTaskViewModel

@{
    ViewData["Title"] = "Edit Task";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-pencil-square"></i> Edit Task Parameters</h2>
    <a asp-controller="Tasks" asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-x-circle"></i> Cancel
    </a>
</div>

<div class="card-box">
    <form id="editTaskForm">
        <input type="hidden" id="TaskId" value="@Model.Id" />

        <div class="mb-3">
            <label class="form-label fw-bold">Task Title</label>
            <input id="Title" class="form-control" value="@Model.Title" required />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Detailed Description</label>
            <textarea id="Description" class="form-control" rows="4">@Model.Description</textarea>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Task Status</label>
            <select id="Status" class="form-select" style="border-radius: 8px;">
                <option value="Pending" selected="@(Model.Status == "Pending" ? "selected" : null)">Pending</option>
                <option value="In Progress" selected="@(Model.Status == "In Progress" ? "selected" : null)">In Progress</option>
                <option value="Completed" selected="@(Model.Status == "Completed" ? "selected" : null)">Completed</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Deadline Expiry Date</label>
            <input id="DueDate" type="date" class="form-control" value="@Model.DueDate.ToString("yyyy-MM-dd")" required />
        </div>

        <button type="submit" class="btn btn-success px-4">
            <i class="bi bi-save"></i> Update Task Details
        </button>
    </form>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#editTaskForm").on("submit", function (e) {
                e.preventDefault();

                var id = $("#TaskId").val();
                
              
                var taskData = {
                    Id: parseInt(id),
                    Title: $("#Title").val(),
                    Description: $("#Description").val(),
                    Status: $("#Status").val(),
                    DueDate: $("#DueDate").val()
                };

                $.ajax({
                    url: '/Tasks/UpdateAjax/' + id,
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(taskData),
                    success: function (response) {
                        alert(response.message || "Task Updated Successfully!");
                        window.location.href = '/Tasks/Index';
                    },
                    error: function (xhr) {
                        alert("Error: " + (xhr.responseJSON?.message || "Failed to sync changes."));
                    }
                });
            });
        });
    </script>
}