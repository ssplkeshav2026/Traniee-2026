@model List<TaskManagement.MVC.ViewModels.UserManagementViewModel>

@* ... (Keep your existing TempData/Header code) ... *@

<table class="table align-middle mb-0">
    <thead class="table-light text-secondary">
        <tr>
            <th class="ps-4" style="width: 30%;">User Email Account</th>
            <th style="width: 20%;">Status</th> <!-- Added Status Column -->
            <th style="width: 25%;">Current Active Roles</th>
            <th class="text-end pe-4" style="width: 25%;">Privilege Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr class="hover-actions">
                <td class="ps-4">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-person-circle fs-3 text-secondary me-3"></i>
                        <span class="fw-semibold text-dark">@user.Email</span>
                    </div>
                </td>
           
                <td>
                    @if (user.Active)
                    {
                        <span class="badge bg-success-subtle text-success border border-success">
                            <i class="bi bi-check-circle-fill me-1"></i> Active
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger-subtle text-danger border border-danger">
                            <i class="bi bi-x-circle-fill me-1"></i> Inactive
                        </span>
                    }
                </td>
                <td>
               
                </td>
                <td class="text-end pe-4">
                    <a asp-controller="Users"
                           asp-action="ManageRoles"
                           asp-route-userId="@user.Id"
                           class="btn btn-sm btn-outline-primary px-3 border-2 fw-bold transition-all">
                        <i class="bi bi-shield-lock-fill me-1"></i> Edit Roles
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>