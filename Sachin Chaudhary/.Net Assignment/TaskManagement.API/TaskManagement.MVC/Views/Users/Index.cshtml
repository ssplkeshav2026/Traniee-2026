@model List<TaskManagement.MVC.ViewModels.UserManagementViewModel>

@{
    ViewData["Title"] = "System Users";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people"></i> Registered Corporate Users</h2>
    <span class="badge bg-primary px-3 py-2 fs-6">Total Registry: @Model.Count</span>
</div>

<div class="card-box">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead class="table-light">
                <tr>
                    <th>User Email Account</th>
                    <th>Current Active Roles</th>
                    <th class="text-end">Privilege Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-4">No workspace users found in the system.</td>
                    </tr>
                }
                else
                {
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-person-circle fs-3 text-secondary me-3"></i>
                                    <span class="fw-semibold text-dark">@user.Email</span>
                                </div>
                            </td>
                            <td>
                                @if (user.Roles == null || !user.Roles.Any())
                                {
                                    <span class="badge bg-secondary opacity-75">No Roles Configured</span>
                                }
                                else
                                {
                                    @foreach (var role in user.Roles)
                                    {
                                        <span class="badge @(role == "Admin" ? "bg-danger" : role == "Manager" ? "bg-info text-dark" : "bg-success") me-1 px-2 py-1 text-capitalize">
                                            @role
                                        </span>
                                    }
                                }
                            </td>
                            <td class="text-end">
                                <a asp-controller="Users" asp-action="ManageRoles" asp-route-userId="@user.Id" class="btn btn-sm btn-outline-primary px-3">
                                    <i class="bi bi-shield-check"></i> Edit Roles
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>