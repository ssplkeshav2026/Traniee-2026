@model List<TaskManagement.MVC.ViewModels.Tasks.TaskResponseViewModel>

@{
    ViewData["Title"] = "My Tasks";
}

<div class="container mt-4">
    <h3 class="mb-3">My Assigned Tasks</h3>

    <div class="card shadow">
        <div class="card-body">
            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-info">
                    No assigned tasks found.
                </div>
            }
            else
            {
                <table class="table table-bordered table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Title</th>
                            <th>Description</th>
                            <th>Assigned By</th>
                            <th>Due Date</th>
                            <th>Status</th>
                            <th>Update</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var task in Model)
                        {
                            <tr data-task-id="@task.Id">
                                <td>@task.Title</td>
                                <td>@task.Description</td>
                                <td>@task.AssignedByUserName</td>
                                <td>@task.DueDate.ToString("dd-MM-yyyy")</td>

                                <td>
                                    <select class="form-select status-dropdown">
                                        <option value="1" selected="@(task.Status == 1)">Pending</option>
                                        <option value="2" selected="@(task.Status == 2)">In Progress</option>
                                        <option value="3" selected="@(task.Status == 3)">Completed</option>
                                    </select>
                                </td>

                                <td>
                                    <button type="button" class="btn btn-sm btn-success update-status">
                                        Update
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">
                    Back
                </a>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            $(".update-status").click(function () {

                var row = $(this).closest("tr");
                var taskId = row.data("task-id");
                var status = row.find(".status-dropdown").val();

                $.ajax({
                    url: '/Tasks/UpdateStatus',
                    type: 'POST',
                    data: {
                        id: taskId,
                        status: status
                    },
                    success: function (response) {
                        alert(response.message);
                    },
                    error: function () {
                        alert("Something went wrong while updating status.");
                    }
                });

            });

        });
    </script>
}