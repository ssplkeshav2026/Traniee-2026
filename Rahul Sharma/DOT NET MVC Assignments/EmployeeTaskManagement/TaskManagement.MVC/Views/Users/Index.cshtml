@model List<TaskManagement.MVC.ViewModels.Users.UserListViewModel>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Manage Users</h3>

        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">
            Back to Dashboard
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card shadow">
        <div class="card-body">
            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-info">
                    No users found.
                </div>
            }
            else
            {
                <table class="table table-bordered table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th width="220">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr id="user-row-@user.Id">
                                <td>@user.FullName</td>
                                <td>@user.Email</td>
                                <td>
                                    <span class="badge bg-primary">
                                        @(user.Roles.FirstOrDefault() ?? "No Role")
                                    </span>
                                </td>
                                <td>
                                    <a asp-action="Details"
                                       asp-route-id="@user.Id"
                                       class="btn btn-sm btn-info">
                                        Details
                                    </a>

                                    <button type="button"
                                            class="btn btn-sm btn-danger delete-user"
                                            data-id="@user.Id">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            $(".delete-user").click(function () {

                var userId = $(this).data("id");

                if (!confirm("Are you sure you want to delete this user?")) {
                    return;
                }

                $.ajax({
                    url: '/Users/Delete',
                    type: 'POST',
                    data: { id: userId },
                    success: function (response) {
                        alert(response.message);

                        if (response.success) {
                            $("#user-row-" + userId).remove();
                        }
                    },
                    error: function () {
                        alert("Something went wrong while deleting user.");
                    }
                });

            });

        });
    </script>
}