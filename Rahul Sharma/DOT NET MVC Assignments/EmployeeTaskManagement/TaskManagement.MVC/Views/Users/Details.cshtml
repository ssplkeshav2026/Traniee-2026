@model TaskManagement.MVC.ViewModels.Users.UserDetailsViewModel

@{
    ViewData["Title"] = "User Details";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>User Details</h3>

        <a asp-action="Index" class="btn btn-secondary">
            Back
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card shadow">
        <div class="card-header bg-dark text-white">
            @Model.FirstName @Model.LastName
        </div>

        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">User Id</dt>
                <dd class="col-sm-9">@Model.Id</dd>

                <dt class="col-sm-3">First Name</dt>
                <dd class="col-sm-9">@Model.FirstName</dd>

                <dt class="col-sm-3">Last Name</dt>
                <dd class="col-sm-9">@Model.LastName</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3">Current Role</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-primary">
                        @(Model.Roles.FirstOrDefault() ?? "No Role")
                    </span>
                </dd>
            </dl>

            <hr />

            <h5>Change Role</h5>

            <form asp-action="ChangeRole" method="post">
                <input type="hidden" name="id" value="@Model.Id" />

                <div class="row">
                    <div class="col-md-6">
                        <select name="role" class="form-select">
                            @foreach (var role in Model.RoleList)
                            {
                                <option value="@role.Value"
                                        selected="@(role.Value == Model.SelectedRole)">
                                    @role.Text
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <button type="submit" class="btn btn-success">
                            Update Role
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>