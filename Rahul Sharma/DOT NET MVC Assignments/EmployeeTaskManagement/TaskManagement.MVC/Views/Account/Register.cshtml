


@model TaskManagement.MVC.ViewModels.Auth.RegisterViewModel

@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}

<div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center bg-light">
    <div class="row w-100 justify-content-center">
        <div class="col-xl-9 col-lg-10 col-md-11">

            <div class="card border-0 shadow-lg overflow-hidden">
                <div class="row g-0">

                    <!-- Left Side -->
                    <div class="col-lg-5 d-none d-lg-flex bg-success text-white p-5 flex-column justify-content-center">
                        <h1 class="fw-bold mb-3">Create Your Account</h1>
                        <p class="fs-5">
                            Join the Employee Task Management System and start managing tasks securely.
                        </p>

                        <div class="mt-4">
                            <p class="mb-2">
                                <i class="bi bi-check-circle-fill me-2"></i> Secure Registration
                            </p>
                            <p class="mb-2">
                                <i class="bi bi-check-circle-fill me-2"></i> JWT Authentication
                            </p>
                            <p class="mb-0">
                                <i class="bi bi-check-circle-fill me-2"></i> Role Based Access
                            </p>
                        </div>
                    </div>

                    <!-- Right Side -->
                    <div class="col-lg-7 bg-white">
                        <div class="p-5">

                            <div class="text-center mb-4">
                                <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                                     style="width:70px; height:70px;">
                                    <i class="bi bi-person-plus fs-2"></i>
                                </div>

                                <h3 class="fw-bold mb-1">Register Account</h3>
                                <p class="text-muted mb-0">Please fill in your details</p>
                            </div>

                            <form asp-action="Register" method="post">
                                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="FirstName" class="form-label fw-semibold"></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light">
                                                <i class="bi bi-person"></i>
                                            </span>
                                            <input asp-for="FirstName"
                                                   class="form-control"
                                                   placeholder="First name" />
                                        </div>
                                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label asp-for="LastName" class="form-label fw-semibold"></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light">
                                                <i class="bi bi-person"></i>
                                            </span>
                                            <input asp-for="LastName"
                                                   class="form-control"
                                                   placeholder="Last name" />
                                        </div>
                                        <span asp-validation-for="LastName" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label fw-semibold"></label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light">
                                            <i class="bi bi-envelope"></i>
                                        </span>
                                        <input asp-for="Email"
                                               class="form-control"
                                               placeholder="Enter email address" />
                                    </div>
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Password" class="form-label fw-semibold"></label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light">
                                            <i class="bi bi-lock"></i>
                                        </span>
                                        <input asp-for="Password"
                                               type="password"
                                               class="form-control"
                                               placeholder="Create password" />
                                    </div>
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>

                                <div class="alert alert-light border small">
                                    <i class="bi bi-info-circle me-1"></i>
                                    Use a strong password with uppercase, lowercase, number, and special character.
                                </div>

                                <div class="d-grid mt-4">
                                    <button type="submit" class="btn btn-success btn-lg">
                                        <i class="bi bi-person-plus me-1"></i> Register
                                    </button>
                                </div>
                            </form>

                            <div class="text-center mt-4">
                                <span class="text-muted">Already have an account?</span>
                                <a asp-action="Login" class="fw-semibold text-decoration-none">
                                    Login
                                </a>
                            </div>

                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}