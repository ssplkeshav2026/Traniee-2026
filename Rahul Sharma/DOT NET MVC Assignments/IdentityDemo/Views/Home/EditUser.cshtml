


@model IdentityDemo.ViewModel.EditUserViewModel

@{
    ViewData["Title"] = "Edit User";
}

<div class="container mt-5">

    ```
    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card shadow-lg border-0">

                <div class="card-header bg-primary text-white text-center">
                    <h3 class="mb-0">Edit Profile</h3>
                </div>

                <div class="card-body p-4">

                    <form asp-action="EditUser"
                          method="post"
                          enctype="multipart/form-data">

                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="ExistingImage" />
                        <input type="hidden" asp-for="ReturnUrl" />

                        <div asp-validation-summary="All"
                             class="text-danger mb-3">
                        </div>

                        @if (!string.IsNullOrEmpty(Model.ExistingImage))
                        {
                            <div class="text-center mb-4">
                                <img src="@Model.ExistingImage"
                                     alt="Profile"
                                     class="rounded-circle border shadow"
                                     style="width:150px;height:150px;object-fit:cover;" />

                                <p class="mt-2 text-muted">
                                    Current Profile Picture
                                </p>
                            </div>
                        }

                        <div class="mb-3">
                            <label asp-for="Name"
                                   class="form-label fw-bold">
                            </label>

                            <input asp-for="Name"
                                   class="form-control" />

                            <span asp-validation-for="Name"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email"
                                   class="form-label fw-bold">
                            </label>

                            <input asp-for="Email"
                                   class="form-control" />

                            <span asp-validation-for="Email"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber"
                                   class="form-label fw-bold">
                            </label>

                            <input asp-for="PhoneNumber"
                                   class="form-control" />

                            <span asp-validation-for="PhoneNumber"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="form-check form-switch mb-4">
                            <input asp-for="Status"
                                   class="form-check-input" />

                            <label asp-for="Status"
                                   class="form-check-label">
                                Active User
                            </label>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ProfileImage"
                                   class="form-label fw-bold">
                                Upload New Profile Picture
                            </label>

                            <input asp-for="ProfileImage"
                                   type="file"
                                   class="form-control" />
                        </div>

                        <div class="d-flex justify-content-between">

                            <a href="@(string.IsNullOrEmpty(Model.ReturnUrl) ? Url.Action("Index", "Home") : Model.ReturnUrl)"
                               class="btn btn-secondary">
                                ← Back
                            </a>

                            <button type="submit"
                                    class="btn btn-success">
                                Save Changes
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>
    ```

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
