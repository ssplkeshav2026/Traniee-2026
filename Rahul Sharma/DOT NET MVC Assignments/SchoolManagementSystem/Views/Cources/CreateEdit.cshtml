@model SchoolManagementSystem.ViewModels.CourcesViewModel

@{
    ViewData["Title"] = Model.CourceId == 0 ? "Create Cource" : "Edit Cource";
}

<h1>@ViewData["Title"]</h1>

<h4>Cource</h4>
<hr />

<div class="row">
    <div class="col-md-4">

        <form asp-action="Save" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="CourceId" />

            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="control-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="GradeId" class="control-label"></label>

                <select asp-for="GradeId"
                        class="form-control"
                        asp-items="ViewBag.GradeId">
                </select>

                <span asp-validation-for="GradeId" class="text-danger"></span>
            </div>

            <br />

            <div class="form-group">

                <button type="submit" class="btn btn-success">
                    @(Model.CourceId == 0 ? "Create" : "Update")
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Back
                </a>

            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}