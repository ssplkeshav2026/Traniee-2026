@model SchoolManagementSystem.ViewModels.DashboardViewModel

<style>
    .student-section {
        background-color: #f4f6f9;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0px 2px 8px rgba(0,0,0,0.1);
    }

    .student-heading {
        background-color: dimgrey;
        color: white;
        padding: 12px;
        border-radius: 8px;
        text-align: center;
        font-weight: bold;
        margin-bottom: 25px;
    }

    .student-card {
        background: linear-gradient(135deg, #343a40, #495057);
        color: white;
        border-radius: 12px;
        text-align: center;
        transition: 0.3s ease;
        box-shadow: 0px 4px 10px rgba(0,0,0,0.2);
    }

        .student-card:hover {
            transform: translateY(-5px);
        }

        .student-card h5 {
            color: #ffc107;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .student-card h2 {
            font-size: 35px;
            font-weight: bold;
        }
</style>

<div class="student-section">

    <h3 class="student-heading">
        Student Statistics
    </h3>

    <div class="row">

        <div class="col-md-4 mb-3">
            <div class="card p-3 student-card">
                <h5>Total Students</h5>
                <h2>@Model.TotalStudents</h2>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card p-3 student-card">
                <h5>Active Students</h5>
                <h2>@Model.ActiveStudents</h2>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card p-3 student-card">
                <h5>Inactive Students</h5>
                <h2>@Model.InactiveStudents</h2>
            </div>
        </div>

    </div>

</div>