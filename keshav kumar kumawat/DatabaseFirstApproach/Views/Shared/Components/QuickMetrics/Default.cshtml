@model DatabaseFirstApproach.Models.ViewModel.DashboardVM

<div class="row mt-4">

    <!-- Total Teachers -->
    <div class="col-md-3">

        <div class="card bg-primary text-white mb-3">

            <div class="card-body text-center">

                <h5>Total Teachers</h5>

                <h2>@Model.TotalTeachers</h2>

            </div>

        </div>

    </div>

    <!-- Total Parents -->
    <div class="col-md-3">

        <div class="card bg-success text-white mb-3">

            <div class="card-body text-center">

                <h5>Total Parents</h5>

                <h2>@Model.TotalParents</h2>

            </div>

        </div>

    </div>

    <!-- Total Courses -->
    <div class="col-md-3">

        <div class="card bg-warning text-dark mb-3">

            <div class="card-body text-center">

                <h5>Total Courses</h5>

                <h2>@Model.TotalCourses</h2>

            </div>

        </div>

    </div>

    <!-- Total Grades -->
    <div class="col-md-3">

        <div class="card bg-danger text-white mb-3">

            <div class="card-body text-center">

                <h5>Total Grades</h5>

                <h2>@Model.TotalGrades</h2>

            </div>

        </div>

    </div>

</div>