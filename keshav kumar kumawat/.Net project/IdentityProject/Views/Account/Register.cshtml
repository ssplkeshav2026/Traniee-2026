@model IdentityProject.Models.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<div class="d-flex justify-content-center align-items-center vh-100 bg-light">

    <div class="card shadow-lg p-4" style="width:450px; border-radius:15px;">

        <h2 class="text-center text-success mb-4">
            Create Account
        </h2>

        <form asp-action="Register" method="post" autocomplete="off">

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label class="form-label fw-bold">First Name</label>
                <input asp-for="FirstName" class="form-control" placeholder="Enter your firstname" autocomplete="off" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Last Name</label>
                <input asp-for="LastName" class="form-control" placeholder="Enter your lastname" autocomplete="off" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Email</label>
                <input asp-for="Email" class="form-control" placeholder="Enter your email" autocomplete="off" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" autocomplete="new-password" />
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm your password" autocomplete="new-password" />
            </div>

            <button type="submit" class="btn btn-success w-100">Register</button>

            <div class="text-center mt-3">
                Already have an account?
                <a asp-action="Login" asp-controller="Account" class="text-decoration-none">Login</a>
            </div>

        </form>
    </div>
</div>