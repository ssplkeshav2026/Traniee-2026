@model dynamic

<h2 class="mb-4">User Management</h2>

<table class="table table-striped table-hover">

    <thead class="table-dark">
        <tr>
            <th>User Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Status</th>
            <th width="220">Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var user in Model)
        {
            <tr>

                <td>@user.UserName</td>
                <td>@user.Email</td>

                <td>
                    <form asp-action="UpdateRole" method="post" class="d-flex">

                        <input type="hidden" name="userId" value="@user.Id" />

                               @* Admin *@
                       <div class="form-check">
                           <input class="form-check-input" type="checkbox" name="roles" value="Admin" 
                           @(user.Roles.Contains("Admin")?"checked":"")/>

                           <label class="form-check-label">Admin</label>
                       </div>

                        @* Manager *@
                       <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="roles" value="Manager"
                           @(user.Roles.Contains("Manager")?"checked":"")/>

                            <label class="form-check-label">Manager</label>
                       </div>

                        @* Member *@
                       <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="roles" value="Member"
                           @(user.Roles.Contains("Member")?"checked":"")/>

                            <label class="form-check-label">Member</label>
                       </div>

                        <button type="submit" class="btn btn-primary">Save</button>

                    </form>
                </td>

                <td>

                    @if (user.IsActive)
                    {
                        <span class="text-success fw-bold">Active</span>
                    }
                    else
                    {
                        <span class="text-danger fw-bold">Inactive</span>
                    }

                </td>

                <td>

                    <form asp-action="ToggleStatus" method="post">

                        <input type="hidden" name="userId" value="@user.Id" />

                        @if (user.IsActive)
                        {
                            <button type="submit" class="btn btn-danger">Deactivate</button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-success">Activate</button>
                        }

                    </form>

                </td>
            </tr>
        }
    </tbody>
</table>