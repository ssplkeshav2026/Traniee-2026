@model List<TaskManagementSystemMVC.ViewModel.TaskViewModel>
@{
    ViewData["Title"] = "My Tasks";
}

<h2>My Tasks</h2>
<hr />

@if (!Model.Any())
{
    <div class="alert alert-info">No tasks assigned to you yet.</div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Status</th>
                <th>Due Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var task in Model)
            {
                <tr>
                    <td>@task.Title</td>
                    <td>@task.Description</td>
                    <td>
                        <span class="badge
                            @(task.Status == "Pending" ? "bg-warning" :
                                task.Status == "InProgress" ? "bg-info" : "bg-success")">
                            @task.Status
                        </span>
                    </td>
                    <td>@task.DueDate.ToString("yyyy-MM-dd")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@task.Id"
                           class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@task.Id"
                           class="btn btn-sm btn-warning">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
