@{
    ViewData["Title"] = "Dashboard";
}

<p class="page-title">Dashboard</p>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card p-3">
            <p class="fw-semibold mb-1">All Tasks</p>
            <small class="text-muted">View and manage all tasks</small>
            <div class="mt-3">
                <a asp-controller="Task" asp-action="Index"
                   class="btn btn-dark btn-sm">
                    View Tasks
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3">
            <p class="fw-semibold mb-1">My Tasks</p>
            <small class="text-muted">Tasks assigned to you</small>
            <div class="mt-3">
                <a asp-controller="Task" asp-action="MyTasks"
                   class="btn btn-dark btn-sm">
                    View My Tasks
                </a>
            </div>
        </div>
    </div>

    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <div class="col-md-4">
            <div class="card p-3">
                <p class="fw-semibold mb-1">New Task</p>
                <small class="text-muted">Create and assign a task</small>
                <div class="mt-3">
                    <a asp-controller="Task" asp-action="Create"
                       class="btn btn-dark btn-sm">
                        Create Task
                    </a>
                </div>
            </div>
        </div>
    }
</div>